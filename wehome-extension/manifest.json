{
  "manifest_version": 3,
  "name": "Wehome — Book Smarter in Korea",
  "version": "1.0.0",
  "description": "에어비앤비 숙소 페이지에서 위홈(Wehome.me) 배너를 표시합니다. Same Home in Better Value than Airbnb.",
  "permissions": [],
  "host_permissions": [
    "https://*.airbnb.com/*",
    "https://*.airbnb.co.kr/*"
  ],
  "content_scripts": [
    {
      "matches": [
        "https://*.airbnb.com/rooms/*",
        "https://*.airbnb.co.kr/rooms/*"
      ],
      "js": ["content.js"],
      "css": ["content.css"],
      "run_at": "document_idle"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Wehome — 같은 숙소 더 저렴하게",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
